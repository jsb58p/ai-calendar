{
  "expo": {
    "name": "SchedulerAI",
    "slug": "schedulerai",
    "scheme": "schedulerai",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["android"],
    "android": {
      "package": "com.schedulerai.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "schedulerai" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "userInterfaceStyle": "dark",
    "experiments": {
      "typedRoutes": true
    }
  }
}
